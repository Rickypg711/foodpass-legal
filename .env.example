# Phase 1 web ordering (default off).
NEXT_PUBLIC_ORDERING_ENABLED=false

# Public site URL for Mercado Pago back_urls.
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel Preview: omit NEXT_PUBLIC_SITE_URL (API uses preview host) — see docs/WEB_MP_VERCEL_PREVIEW_TESTING.md
# Vercel Production: https://www.comeleal.com

# Mercado Pago sandbox mode for Checkout Pro redirect (sandbox_init_point).
MERCADO_PAGO_SANDBOX=true

# Checkout Pro Marketplace: commission rate on preference (seller OAuth token unchanged).
# Omitted or 0 = no marketplace_fee field. Example 1.7%:
MERCADO_PAGO_MARKETPLACE_FEE_RATE=0.017

# IPN / webhook — required on each preference (notification_url). FOODPASS Cloud Function:
MERCADO_PAGO_WEBHOOK_URL=https://us-central1-foodpass-18b33.cloudfunctions.net/mercadopagoWebhook

# Optional MP web debug (see docs/WEB_MP_DEBUGGING.md)
# NEXT_PUBLIC_MP_WEB_DEBUG=true
# MP_WEB_DEBUG=true

# Firebase Admin for /api/mercado-pago/create-preference (server-only).
# Copy this file to .env.local — Next dev does not read shell exports from another repo.
#
# Local: file path is OK
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/foodpass-18b33-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
#
# Vercel Preview / Production: use JSON in dashboard (Sensitive), not a file path:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
